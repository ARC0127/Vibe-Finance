{
  "version": "0.2.0",
  "data_gates": {
    "minimum_price_sources": 2,
    "minimum_history_points": 20,
    "max_snapshot_age_hours": 120,
    "fund": {
      "require_tiantian_crosscheck": true,
      "require_fund_company_or_exchange_source": true,
      "maximum_nav_age_trading_days": 2,
      "maximum_holdings_age_days": 120,
      "minimum_aum_cny": 100000000,
      "active_manager_minimum_tenure_days": 365,
      "allowed_subscription_statuses": ["OPEN", "LIMITED_OPEN"]
    }
  },
  "risk": {
    "broad_market_shock_daily_return": -0.03,
    "single_asset_shock_daily_return": -0.04,
    "exit_below_ma20_ratio": 0.95,
    "maximum_next_open_gap": 0.015,
    "max_single_stock_weight": 0.08,
    "max_single_etf_weight": 0.20,
    "max_single_open_end_fund_weight": 0.15,
    "bond_fund_target_weight": 0.15,
    "gold_fund_target_weight": 0.10,
    "cash_etf_target_weight": 0.35,
    "cash_etf_max_volatility": 0.03,
    "max_total_equity_weight": 0.60,
    "minimum_cash_weight": 0.15
  },
  "diversification": {
    "maximum_positions": 6,
    "maximum_new_buys_per_cycle": 2,
    "one_position_per_exposure_group": true,
    "bucket_weight_caps": {
      "core_equity": 0.35,
      "small_growth_equity": 0.15,
      "industry_equity": 0.10,
      "dividend_equity": 0.15,
      "gold": 0.10,
      "fixed_income": 0.20,
      "cash_management": 0.35,
      "unclassified_equity": 0.10
    }
  },
  "fund_orders": {
    "signal_after_cutoff_prices_at": "next_open_day_confirmed_nav",
    "daily_cutoff": "15:00_Asia/Shanghai",
    "minimum_subscription_cny": 10.0,
    "share_precision": 4,
    "nav_settlement_requires": [
      "nav_date_after_signal_date",
      "tiantian_crosscheck",
      "fund_company_source",
      "fees_verified",
      "subscription_or_redemption_open"
    ]
  },
  "costs": {
    "commission_rate": 0.0003,
    "minimum_commission_cny": 5.0,
    "stock_sell_stamp_rate": 0.0005,
    "stock_transfer_fee_rate": 0.00001,
    "commission_includes_exchange_handling_fee": true,
    "commission_basis": "SIMULATION_ASSUMPTION_VERIFY_AGAINST_BROKER_ACCOUNT"
  },
  "schedules": {
    "pre_open_review": "weekdays_08:00_Asia/Shanghai",
    "open_settlement": "weekdays_09:35_Asia/Shanghai",
    "short_cycle": "weekdays_after_close",
    "fund_nav_cycle": "weekdays_22:30_Asia/Shanghai",
    "long_cycle": "weekly",
    "reflection_evolution_cycle": "saturday_20:30_Asia/Shanghai",
    "document_log_cycle": "daily_23:10_Asia/Shanghai",
    "high_frequency": {
      "enabled": false,
      "activation_requires": [
        "licensed_point_in_time_data",
        "slippage_and_fill_model",
        "walk_forward_backtest",
        "out_of_sample_pass",
        "explicit_user_confirmation"
      ]
    }
  }
}
