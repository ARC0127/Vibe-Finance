      "target_weights": {
        "core_equity": 0.08,
        "small_growth_equity": 0.08,
        "industry_equity": 0.05,
        "dividend_equity": 0.06,
        "unclassified_equity": 0.05
      }
    },
    "defensive": {
      "maximum_abs_daily_return": 0.01,
