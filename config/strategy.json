    "cold_start": {
      "enabled": true,
      "eligible_asset_types": ["equity_etf", "gold_etf"],
      "dip_exposure_groups": ["csi300", "csi500", "csi1000", "chinext"]
    }
  },
  "daily_execution": {
    "enabled": true,
    "allow_conditional_preopen_order": true,
